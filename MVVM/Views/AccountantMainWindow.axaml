<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MVVM.ViewModels"
        xmlns:equipment="clr-namespace:MVVM.Models.Dto.Equipment"
        xmlns:reports="clr-namespace:MVVM.Models.Dto.Reports"
        xmlns:models="clr-namespace:MVVM.Models.Dto.Users"
        x:Class="MVVM.Views.AccountantMainWindow"
        Title="Админка"
        Width="800" Height="600"
        x:DataType="vm:AccountantViewModel"
        Background="#F3E8FF">

    <TabControl>
        <TabItem Header="Дашборд " Foreground="Black">
            <ScrollViewer Margin="10">
                <ListBox ItemsSource="{Binding DashboardItems}" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" /> <!-- Название -->
                                    <ColumnDefinition Width="Auto" /> <!-- Значение -->
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Label}" FontWeight="Bold" Foreground="{Binding Foreground}" Grid.Column="0"/>
                                <TextBlock Text="{Binding Value}" Foreground="{Binding Foreground}" Grid.Column="1" HorizontalAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Оборудование" Foreground="Black">
            <ScrollViewer Margin="10">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,5">
                        <TextBlock Text="ID" Width="50" FontWeight="Bold" Foreground="#4B3F2F"/>
                        <TextBlock Text="Наименование" Width="150" FontWeight="Bold" Foreground="#4B3F2F"/>
                        <TextBlock Text="Категория" Width="150" FontWeight="Bold" Foreground="#4B3F2F"/>
                        <TextBlock Text="Стоимость" Width="150" FontWeight="Bold" Foreground="#4B3F2F"/>
                        <TextBlock Text="Статус" Width="150" FontWeight="Bold" Foreground="#4B3F2F"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Equipments}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="equipment:EquipmentShortResponse">
                                <Border Background="#FFF8F0" BorderBrush="#5C2E00" BorderThickness="1" Padding="5" Margin="2" CornerRadius="3">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding Id}" Width="50" Foreground="#4B3F2F"/>
                                        <TextBlock Text="{Binding Name}" Width="150" Foreground="#4B3F2F"/>
                                        <TextBlock Text="{Binding Category}" Width="150" Foreground="#4B3F2F"/>
                                        <TextBlock Text="{Binding Cost}" Width="150" Foreground="#4B3F2F"/>
                                        <TextBlock Text="{Binding Status}" Width="150" Foreground="#4B3F2F"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Назначения" Foreground="Black">
            <StackPanel Margin="10" Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <ComboBox ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}" Width="200">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:EmployeeDropdown">
                                <TextBlock Text="{Binding FullName}" Foreground="#4B3F2F"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox ItemsSource="{Binding AvailableEquipment}" SelectedItem="{Binding SelectedEquipment}" Width="200">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="equipment:EquipmentShortResponse">
                                <TextBlock Text="{Binding Name}" Foreground="#4B3F2F"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBox Width="200" Watermark="Причина" Text="{Binding Reason, Mode=TwoWay}"
                             Background="#FFF8F0" Foreground="#4B3F2F" BorderBrush="#5C2E00" BorderThickness="1" CornerRadius="5" CaretBrush="#4B3F2F"/>

                    <Button Content="Выдать" Command="{Binding AssignCommand}"
                            Background="#7B3F00" Foreground="White" BorderBrush="#5C2E00" BorderThickness="1" CornerRadius="8">
                        <Button.Styles>
                            <Style Selector="Button:hover">
                                <Setter Property="Background" Value="#5C2E00"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </StackPanel>
            </StackPanel>
        </TabItem>

        <TabItem Header="Отчёты" Foreground="Black">
            <ScrollViewer Margin="10">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,5">
                        <TextBlock Text="ID сотрудника" Width="50" FontWeight="Bold" Foreground="#4B3F2F"/>
                        <TextBlock Text="Всего записей" Width="150" FontWeight="Bold" Foreground="#4B3F2F"/>
                        <TextBlock Text="Отсутствует" Width="150" FontWeight="Bold" Foreground="#4B3F2F"/>
                        <TextBlock Text="Последняя инвентаризация" Width="220" FontWeight="Bold" Foreground="#4B3F2F"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Summary}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="reports:InventorySummaryResponse">
                                <Border Background="#FFF8F0" BorderBrush="#5C2E00" BorderThickness="1" Padding="5" Margin="2" CornerRadius="3">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding EmployeeId}" Width="50" Foreground="#4B3F2F"/>
                                        <TextBlock Text="{Binding TotalRecords}" Width="150" Foreground="#4B3F2F"/>
                                        <TextBlock Text="{Binding MissingCount}" Width="150" Foreground="#4B3F2F"/>
                                        <TextBlock Text="{Binding LastInventory, StringFormat=dd.MM.yyyy}" Width="220" Foreground="#4B3F2F"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Window>